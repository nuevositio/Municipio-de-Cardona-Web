# ── .env para producción en cPanel (cardona.milocapp.uy) ──────────────────────
# Copiá este archivo como .env en la raíz del proyecto en el servidor
# y completá cada valor antes de iniciar la aplicación.

NODE_ENV=production
PORT=3000

# URL del frontend (el mismo subdominio, sin barra final)
FRONTEND_ORIGIN=https://cardona.milocapp.uy

# Sesión — generá un string aleatorio de al menos 32 caracteres
SESSION_SECRET=CAMBIAR_POR_STRING_ALEATORIO_SEGURO_32_CHARS

# Neon PostgreSQL
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
DIRECT_URL=postgresql://user:password@host/dbname?sslmode=require

# Supabase Storage
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# Cloudflare Turnstile (producción)
CLOUDFLARE_TURNSTILE_SECRET=CAMBIAR_POR_SECRET_KEY_DE_DASHBOARD

# OpenAI
OPENAI_API_KEY=sk-proj-...

# Variables del frontend (se embeben en el build de Vite — ejecutar ANTES del build)
VITE_API_URL=https://cardona.milocapp.uy
VITE_TURNSTILE_SITE_KEY=CAMBIAR_POR_SITE_KEY_DE_DASHBOARD
