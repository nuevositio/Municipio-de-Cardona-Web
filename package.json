{
  "name": "milocapp-cardona-cloud",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:client": "vite",
    "dev:server": "tsx watch --tsconfig server/tsconfig.json server/src/index.ts",
    "dev:full": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build": "tsc -b && vite build",
    "build:server": "tsc -p server/tsconfig.json",
    "build:production": "npm run build && npm run build:server",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "NODE_ENV=production node app.js",
    "start:server": "node server/dist/index.js",
    "hash": "tsx server/src/scripts/generate-hash.ts",
    "bootstrap": "tsx server/src/scripts/bootstrap-superadmin.ts",
    "db:generate": "drizzle-kit generate --config server/drizzle.config.ts",
    "db:migrate": "tsx server/src/db/migrate.ts",
    "db:studio": "drizzle-kit studio --config server/drizzle.config.ts",
    "db:push": "drizzle-kit push --config server/drizzle.config.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@neondatabase/serverless": "^0.10.4",
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/supabase-js": "^2.49.4",
    "@types/bcryptjs": "^2.4.6",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "connect-pg-simple": "^10.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.41.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "express-session": "^1.19.0",
    "framer-motion": "^12.38.0",
    "helmet": "^8.1.0",
    "lucide-react": "^0.577.0",
    "multer": "^2.1.1",
    "openai": "^6.34.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-google-recaptcha-v3": "^1.11.0",
    "react-helmet-async": "^3.0.0",
    "react-hook-form": "^7.72.0",
    "react-router-dom": "^7.13.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^3.25.56"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.30.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^6.3.5"
  }
}
