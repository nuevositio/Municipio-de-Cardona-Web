# Milocapp Cardona Cloud — Variables de entorno
# Copiar este archivo a .env y completar los valores reales.
# NUNCA comitear el archivo .env al repositorio.

NODE_ENV=development

PORT=4000
FRONTEND_ORIGIN=http://localhost:5173

# Mínimo 64 caracteres aleatorios — genera uno con:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=cambia_esto_por_un_secreto_de_al_menos_64_caracteres_aleatorios

# Neon PostgreSQL
# DATABASE_URL  = connection string con pooling  (para queries en runtime)
# DIRECT_URL    = connection string sin pooling  (para npm run db:migrate)
# Ambas están disponibles en el panel de Neon → Connection Details
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DIRECT_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Supabase Storage
# Obtener en: Supabase → Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Cloudflare Turnstile
# Obtener en: https://dash.cloudflare.com/ → Turnstile
# En desarrollo se puede usar la clave de test (siempre aprueba):
#   secret:  1x0000000000000000000000000000000AA
#   sitekey: 1x00000000000000000000AA
CLOUDFLARE_TURNSTILE_SECRET=1x0000000000000000000000000000000AA
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Bootstrap del superadmin (solo primer arranque, luego se puede eliminar)
# Si estas variables están definidas, se crea el superadmin al iniciar si no hay usuarios.
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_EMAIL=admin@municipiodecardona.gub.uy
SUPERADMIN_PASSWORD=cambia_esto_minimo_12_caracteres

# URL del backend — usada por el frontend (Vite)
# En producción: URL pública del servicio Render
VITE_API_URL=http://localhost:4000
